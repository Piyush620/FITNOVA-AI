NODE_ENV=production
PORT=4000
APP_NAME=FitNova AI
APP_ORIGIN=http://localhost
APP_TRUST_PROXY=true
SWAGGER_ENABLED=true
CORS_ALLOW_LOCALHOST=true
MONGODB_URI=mongodb://mongodb:27017/fitnova-ai
JWT_ACCESS_SECRET=fitnova_local_access_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=fitnova_local_refresh_secret_change_me
JWT_REFRESH_TTL=30d
BCRYPT_SALT_ROUNDS=12
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
POSTGRES_URL=
GLOBAL_RATE_LIMIT_TTL=60000
GLOBAL_RATE_LIMIT=100
AI_RATE_LIMIT_TTL=60000
AI_RATE_LIMIT=12
LOG_LEVEL=info
LOG_TO_FILES=false
